# =================================================
#  Configuration for Project Sentinel
# =================================================
# Copy this file to .env and modify if necessary.
# The default values are optimized for the Docker setup.

# --- SERVER SETTINGS (for server.py) ---
MODEL_NAME=llama3
# This is now controlled by the SQL_CONNECTION_STRING below.
# SQL_DB_PATH=db_data/company.db
DB_PATH=chroma_db
SERVER_HOST=0.0.0.0
SERVER_PORT=8000

# --- LIVE DATABASE CONNECTION ---
# Paste your full connection string from Supabase here.
# It should look like: postgresql://postgres:[YOUR-PASSWORD]@[YOUR-HOST]:5432/postgres
SQL_CONNECTION_STRING=postgresql://postgres.hlcvfbhqzlssbrbnpaxa:Fz06lvweLmMrtvNt@aws-1-ap-south-1.pooler.supabase.com:6543/postgres

# --- INGESTION SETTINGS (for ingest.py) ---
DATA_PATH=Data
EMBEDDING_MODEL_NAME=all-MiniLM-L6-v2
CHUNK_SIZE=1000
CHUNK_OVERLAP=200

# --- CLIENT SETTINGS (for client/src/App.jsx) ---
# This tells the frontend to use the Nginx proxy for API calls.
VITE_API_URL=/api

# --- OLLAMA SETTINGS ---
OLLAMA_HOST=http://host.docker.internal:11434

# --- SUPABASE STORAGE SETTINGS ---
SUPABASE_URL=https://dgaexqaxpdmvacrfhhjo.supabase.co
