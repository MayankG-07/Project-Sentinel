# =========================================
#  Project Sentinel .gitignore
# =========================================

# --- Secrets & Legal ---
.env
# Note: LICENSE is NOT ignored so it is visible on GitHub

# --- Python ---
venv/
.venv/
env/
__pycache__/
*.pyc
*.pyo
*.pyd
.pytest_cache/
.coverage
htmlcov/

# --- Databases & Generated Data ---
chroma_db/
db_data/
# CRITICAL: Ignore all audit logs
audit.log
forensic_audit.log
*.log

# --- Temporary Assets ---
# Ignore rendered PDF images and generated reports
client/public/rendered_pages/

# --- Presentation & Private Guides ---
PRESENTATION_TIPS.md

# --- Node.js / Frontend ---
client/node_modules/
client/dist/
client/.eslintcache
client/npm-debug.log*
client/yarn-debug.log*
client/yarn-error.log*

# --- IDE & Editor ---
.idea/
.vscode/
*.swp
*.swo

# --- OS Files ---
.DS_Store
Thumbs.db
