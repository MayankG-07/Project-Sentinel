# =================================================
#  Configuration for Project Sentinel (Example)
# =================================================

# --- AI & LLM SETTINGS ---
MODEL_NAME=llama3
EMBEDDING_MODEL_NAME=all-MiniLM-L6-v2
OLLAMA_HOST=http://host.docker.internal:11434

# --- DATABASE SETTINGS ---
# Leave empty to use the local SQLite database (db_data/company.db)
# For Live SQL, use the format: postgresql://user:pass@IP_ADDRESS:5432/postgres
SQL_CONNECTION_STRING=
SQL_DB_PATH=db_data/company.db
DB_PATH=chroma_db

# --- INGESTION SETTINGS ---
DATA_PATH=Data
CHUNK_SIZE=1000
CHUNK_OVERLAP=200

# --- SERVER SETTINGS ---
SERVER_HOST=0.0.0.0
SERVER_PORT=8000

# --- CLIENT SETTINGS ---
VITE_API_URL=/api
